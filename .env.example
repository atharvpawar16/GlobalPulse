# Database
DATABASE_URL=postgresql://globalpulse:password@db:5432/globalpulse

# Redis
REDIS_URL=redis://redis:6379

# OpenAI (or leave blank to use Ollama)
OPENAI_API_KEY=sk-...

# Ollama (local LLM fallback)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3

# Mapbox (frontend map)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...

# GDELT
GDELT_API_URL=https://api.gdeltproject.org/api/v2

# ACLED
ACLED_API_KEY=your_acled_key
ACLED_EMAIL=your@email.com

# NASA FIRMS
NASA_FIRMS_API_KEY=your_nasa_key

# USGS Earthquake Feed
USGS_FEED_URL=https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary

# Alert Webhooks
WEBHOOK_SECRET=your_webhook_secret

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE_MINUTES=1440

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
