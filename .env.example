# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Get a free DB at https://neon.tech
POSTGRES_USER=globalpulse
POSTGRES_PASSWORD=changeme
POSTGRES_DB=globalpulse

# For the backend (Neon.tech example):
# ConnectionStrings__Postgres=Host=...neon.tech;Database=neondb;Username=...;Password=...;SSL Mode=Require;Trust Server Certificate=true

# ── Redis (optional — enables live push) ─────────────────────────────────────
# Leave blank to run without live push (app still works in polling mode)
REDIS_URL=redis://localhost:6379

# ── Feed ingestion interval ───────────────────────────────────────────────────
FEED_INTERVAL_MINUTES=5
